generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  name      String
  role      String
  password  String
  createdAt DateTime @default(now())

  schedules    Schedule[]    @relation("DoctorSchedules")
  reservations Reservation[] @relation("PatientReservations")
}

model Schedule {
  id            Int      @id @default(autoincrement())
  doctorId      Int
  availableDate DateTime
  availableTime String
  isBooked      Boolean  @default(false)
  createdAt     DateTime @default(now())

  doctor      User         @relation("DoctorSchedules", fields: [doctorId], references: [id], onDelete: Cascade)
  reservation Reservation?

  @@unique([doctorId, availableDate, availableTime])
}

model Reservation {
  id         Int      @id @default(autoincrement())
  patientId  Int
  scheduleId Int      @unique
  status     String   @default("예약완료")
  createdAt  DateTime @default(now())

  patient  User     @relation("PatientReservations", fields: [patientId], references: [id], onDelete: Cascade)
  schedule Schedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
}
